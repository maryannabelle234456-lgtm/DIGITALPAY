<!DOCTYPE html>
<html>
<head>
  <title>My Bank App</title>
  <script src="https://js.paystack.co/v1/inline.js"></script>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f4f6f8;
    }

    .header {
      background: #0a3d62;
      color: white;
      padding: 20px;
      text-align: center;
    }

    .card {
      background: linear-gradient(135deg, #1e90ff, #3742fa);
      color: white;
      margin: 20px;
      padding: 20px;
      border-radius: 15px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

    .balance {
      font-size: 28px;
      font-weight: bold;
    }

    .actions {
      display: flex;
      justify-content: space-around;
      margin: 20px;
    }

    .btn {
      padding: 10px 20px;
      border: none;
      border-radius: 10px;
      background: #1e90ff;
      color: white;
      cursor: pointer;
    }

    .transactions {
      margin: 20px;
    }

    .transaction {
      background: white;
      padding: 10px;
      margin-bottom: 10px;
      border-radius: 10px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    input {
      padding: 10px;
      margin: 5px;
      width: 80%;
      border-radius: 8px;
      border: 1px solid #ccc;
    }
  </style>
</head>

<body>

  <div class="header">
    <h2>MyBank</h2>
  </div>

  <!-- BALANCE CARD -->
  <div class="card">
    <p>Available Balance</p>
    <div id="balance" class="balance">₦300,000</div>
    <small></small>
  </div>

  <!-- ACTION BUTTONS -->
  <div class="actions">
    <button class="btn" onclick="showPayment()">Pay</button>
    <button class="btn">Withdraw</button>
  </div>

  <!-- PAYMENT FORM -->
  <div id="paymentBox" style="display:none; text-align:center;">
    <h3>Make Payment</h3>
    <form id="paymentForm">
      <input type="text" id="name" placeholder="Your Name" required><br>
      <input type="email" id="email" placeholder="Your Email" required><br>
      <button class="btn" type="submit">Pay ₦5,000</button>
    </form>
  </div>

  <!-- TRANSACTIONS -->
  <div class="transactions">
    <h3>Transactions</h3>
    <div id="txList"></div>
  </div>

  <script>
    let balance = 300000;
    let transactions = [];

    function updateUI() {
      document.getElementById("balance").innerText =
        "₦" + balance.toLocaleString();

      let txHTML = "";
      transactions.forEach(tx => {
        txHTML += `
          <div class="transaction">
            <b>${tx.type}</b><br>
            ₦${tx.amount.toLocaleString()}
          </div>
        `;
      });

      document.getElementById("txList").innerHTML = txHTML;
    }

    function showPayment() {
      document.getElementById("paymentBox").style.display = "block";
    }

    const paymentForm = document.getElementById("paymentForm");

    paymentForm.addEventListener("submit", function(e) {
      e.preventDefault();

      let handler = PaystackPop.setup({
        key: 'pk_test_xxxxxxxxxxxxxxxx', // PUT YOUR KEY
        email: document.getElementById("email").value,
        amount: 500000,
        currency: "NGN",

        callback: function(response) {
          alert("Payment successful!");

          balance += 5000;

          transactions.unshift({
            type: "Credit",
            amount: 5000
          });

          updateUI();
        },

        onClose: function() {
          alert("Transaction cancelled");
        }
      });

      handler.openIframe();
    });

    updateUI();
  </script>


<!-- CUSTOMER CARE BUTTON -->
<button onclick="openChat()" style="
  position:fixed;
  bottom:20px;
  right:20px;
  background:#1e90ff;
  color:white;
  border:none;
  padding:15px;
  border-radius:50%;
  font-size:18px;
  cursor:pointer;
">
💬
</button>

<!-- CHAT BOX -->
<div id="chatBox" style="
  display:none;
  position:fixed;
  bottom:80px;
  right:20px;
  width:300px;
  background:white;
  border-radius:10px;
  box-shadow:0 4px 10px rgba(0,0,0,0.3);
">

  <div style="background:#0a3d62; color:white; padding:10px; border-radius:10px 10px 0 0;">
    Customer Care
    <span onclick="closeChat()" style="float:right; cursor:pointer;">✖</span>
  </div>

  <div id="chatMessages" style="height:200px; overflow-y:auto; padding:10px;">
    <p><b>Support:</b> Hello 👋 How can we help you?</p>
  </div>

  <div style="padding:10px;">
    <input id="chatInput" placeholder="Type message..." style="width:70%; padding:5px;">
    <button onclick="sendMessage()">Send</button>
  </div>

  <div style="padding:10px; font-size:12px; color:gray;">
    📧 support@mybank.com <br>
    📞 +234 800 000 0000
  </div>

</div>

</body>
</html>
